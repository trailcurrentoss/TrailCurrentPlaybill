# =============================================================================
# AI agent configuration (local only — never commit)
# Per global guidance: agent configuration is personal and local; never
# committed to ANY repository. This applies to all agents (Claude, Cursor,
# Copilot, Aider, Continue, Codeium, Tabnine, Sourcery, etc.).
# =============================================================================
.claude
.claude/
.claude.md
CLAUDE.md
CLAUDE.MD
.cursorrules
.cursor/
.github/copilot*
.aider*
.continue/
.codeium/
.tabnine*
.sourcery.yaml

# =============================================================================
# Sandbox / scratch (local only — never commit)
# =============================================================================
sandbox/

# =============================================================================
# Editor / OS noise
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# =============================================================================
# Node / Electron app build outputs
# =============================================================================
node_modules/
app/build/
app/dist/
app/.cache/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# FCC ULS source files (downloaded by build-tools/uls/build-pubsafety.js).
# Only the compact output pubsafety-by-zip3.json.gz is committed; the raw
# 2 GB of .dat files and the 380 MB l_LMpriv.zip are too big for the repo.
# =============================================================================
build-tools/uls/l_LMpriv.zip
build-tools/uls/extracted/
build-tools/uls/pubsafety-by-zip3.json

# =============================================================================
# OS image build outputs (these are large — built artifacts, not source)
# =============================================================================
image/output/
image/cache/
image/out/
image/rsdk/.cache/
image/rsdk/out/
image/rsdk/wget-log*
image/embloader/output/
image/embloader/cache/
*.img
*.img.xz
*.img.gz
*.img.zst
*.qcow2
*.iso
*.tar
*.tar.xz
*.tar.gz
*.tar.zst

# =============================================================================
# ComfyUI working files (the source prompts live in branding/comfyui-prompts.md;
# generated PNGs that are the canonical assets DO get committed under branding/)
# =============================================================================
branding/_candidates/
branding/_drafts/
branding/_working/
*.bak

# =============================================================================
# Local-only secrets (never commit)
# .env carries OAuth credentials that get baked into the build by
# build-tools/embed-yt-credentials.js. Both the source .env and the
# generated default-client.local.js sit in .gitignore.
# =============================================================================
.env
.env.local
.env.*.local
google_client_secret*.json
credentials
controller/src/sources/youtube/default-client.local.js
packaging/**/dist/
