diff --git a/embloader/src/menu/menus/text_menu.c b/embloader/src/menu/menus/text_menu.c
index 20ca679..c86eec1 100644
--- a/embloader/src/menu/menus/text_menu.c
+++ b/embloader/src/menu/menus/text_menu.c
@@ -63,6 +63,36 @@ EFI_STATUS embloader_text_menu_start(embloader_loader **selected, uint64_t *flag
 	if (flags) *flags = 0;
 	if (!menu || !selected) return EFI_INVALID_PARAMETER;
 	*selected = NULL;
+
+	/*
+	 * PLAYBILL PATCH: when timeout == 0, autoboot the default without
+	 * displaying the menu or polling ConIn. Upstream embloader still pumps
+	 * gST->ConIn during the timeout==0 window, so a single byte of phantom
+	 * serial input (e.g. EMI on a floating UART RX line — see Q6A header
+	 * pin 10 / gpio23) preempts auto-boot and traps the user at the menu.
+	 *
+	 * This change makes timeout=0 mean "skip menu entirely" and matches
+	 * the upstream sd-boot menu-disabled / menu-hidden semantics that
+	 * embloader's parser accepts but does not implement.
+	 */
+	if (menu->timeout == 0) {
+		list *q;
+		embloader_loader *def_loader = NULL;
+		if ((q = list_first(menu->loaders))) do {
+			LIST_DATA_DECLARE(item, q, embloader_loader*);
+			if (!item) continue;
+			if (!def_loader) def_loader = item;
+			if (
+				menu->default_entry && item->name &&
+				strcmp(menu->default_entry, item->name) == 0
+			) { def_loader = item; break; }
+		} while ((q = q->next));
+		if (def_loader) {
+			*selected = def_loader;
+			if (flags) *flags |= EMBLOADER_FLAG_AUTOBOOT;
+			return EFI_SUCCESS;
+		}
+	}
 	printf("\n");
 	printf("========================================\n");
 	printf("= Embedded Bootloader menu\n");
