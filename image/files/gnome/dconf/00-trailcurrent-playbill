# TrailCurrent Playbill — system-wide GNOME defaults
#
# Installed at /etc/dconf/db/local.d/00-trailcurrent-playbill, then `dconf
# update` rebuilds the binary db.
#
# Scope: only PRODUCT IDENTITY keys are set here. User-preference keys
# (color-scheme, locale, timezone, keyboard, accessibility) are left alone
# so gnome-initial-setup and the user can choose them on first login.
#
# Keys we lock (see /etc/dconf/db/local.d/locks/) so first-login user-mode
# defaults can't overlay our brand-identity choices.

[org/gnome/desktop/background]
picture-uri='file:///usr/share/backgrounds/trailcurrent-playbill/wallpaper-light.png'
picture-uri-dark='file:///usr/share/backgrounds/trailcurrent-playbill/wallpaper-dark.png'
picture-options='zoom'
primary-color='#0d100c'
secondary-color='#0d100c'

[org/gnome/desktop/screensaver]
picture-uri='file:///usr/share/backgrounds/trailcurrent-playbill/wallpaper-dark.png'
picture-options='zoom'

# Brand chrome — IMPORTANT context:
#
# libadwaita explicitly does NOT honor user-selected GTK themes (per the
# upstream libadwaita docs: "Apps using libadwaita don't use system themes
# and look identical between desktop environments"). On Ubuntu Noble, every
# modern GNOME app (Settings, Files/Nautilus, Software, Calculator, etc.)
# is a libadwaita app and ignores `gtk-theme` entirely.
#
# `accent-color` as a runtime dconf key only exists in libadwaita >= 1.6
# (GNOME 47). Ubuntu Noble ships libadwaita 1.5.0 (GNOME 46), so the
# accent-color key has NO schema entry — setting it is a no-op. The Noble-
# correct way to recolor Yaru is to point gtk-theme at one of the pre-baked
# Yaru color variants (Yaru-sage-dark, Yaru-prussiangreen-dark,
# Yaru-viridian-dark, Yaru-olive-dark, Yaru-bark-dark) which ship with
# yaru-theme-gtk on Noble. Each variant is a full theme tree with its own
# accent baked in via the gresource bundle.
#
# We picked Yaru-viridian-dark (#03875B accent — saturated green-teal) as
# the closest available green-family Yaru variant to the TrailCurrent brand
# green (#52A441). Exact brand-green match is Stage-2 work (fork Yaru-dark
# and swap the accent hex into a TrailCurrent-derivative theme) and is
# documented in docs/RADXA_LESSONS_LEARNED.md.
#
# /usr/share/themes/TrailCurrent-Playbill/ remains installed as a fallback
# for GTK3 / non-libadwaita apps that DO honor user themes (gnome-tweaks,
# some indicators), but is NOT the gtk-theme name we point dconf at.
[org/gnome/desktop/interface]
gtk-theme='Yaru-viridian-dark'
icon-theme='Yaru'

[org/gnome/shell]
favorite-apps=['trailcurrent-playbill.desktop', 'firefox.desktop', 'org.gnome.Nautilus.desktop', 'org.gnome.Terminal.desktop', 'org.gnome.Settings.desktop']
# Empty array → GNOME Shell auto-populates the app picker from /usr/share/applications/.
# (Was previously inheriting Ubuntu's default layout that referenced ~21 apps,
# most of which weren't installed under -minimal — left the picker mostly empty.)
app-picker-layout=@aa{sv} []

[org/gnome/login-screen]
# Use the small corporate wordmark (480x96, white-on-dark) — NOT the 512x512
# Playbill product icon. The product icon is too tall and overlaps the GDM
# password input box.
logo='/usr/share/backgrounds/trailcurrent-playbill/trailcurrent-wordmark.png'
disable-user-list=false

# Argon IR remote's "Power" button launches Playbill (it does NOT power
# the host off). The IR keymap at /etc/rc_keymaps/playbill.toml maps the
# remote's Power scancode to KEY_PROG1 (XF86Launch1); this binding is
# what catches it inside the user's GNOME session and runs the launcher.
[org/gnome/settings-daemon/plugins/media-keys]
custom-keybindings=['/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/playbill-launch/']

[org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/playbill-launch]
name='Launch Playbill'
binding='XF86Launch1'
command='gio launch /usr/share/applications/trailcurrent-playbill.desktop'
