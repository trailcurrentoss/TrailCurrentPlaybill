# TrailCurrent Playbill — GDM (login screen) dconf override
#
# Installed at /etc/dconf/db/gdm.d/00-trailcurrent-playbill-gdm. Compiled
# into /etc/dconf/db/gdm by `dconf update`. GDM reads its dconf via the
# `gdm` profile (separate from user-mode `local`), so user-side settings
# don't apply here — we have to set GDM keys explicitly.

# Login-screen branding — TrailCurrent wordmark (480x96, white-on-dark)
# from the marketing site, NOT the Playbill product icon. The product icon
# is 512x512 and overlaps the password input box on GDM.
[org/gnome/login-screen]
logo='/usr/share/backgrounds/trailcurrent-playbill/trailcurrent-wordmark.png'
banner-message-enable=false
disable-user-list=false
fallback-logo='/usr/share/backgrounds/trailcurrent-playbill/trailcurrent-wordmark.png'

# GDM chrome — Yaru-viridian-dark (saturated green-teal accent #03875B,
# closest pre-baked Yaru variant to the TrailCurrent brand green #52A441).
# NOT TrailCurrent-Playbill: libadwaita doesn't honor user themes (login
# screen widgets are libadwaita). The accent-color dconf key is libadwaita
# 1.6+; Noble has 1.5, so we recolor via gtk-theme variant instead. See
# docs/RADXA_LESSONS_LEARNED.md and the comment block in
# /etc/dconf/db/local.d/00-trailcurrent-playbill for the long version.
[org/gnome/desktop/interface]
gtk-theme='Yaru-viridian-dark'
icon-theme='Yaru'
color-scheme='prefer-dark'

# Background of the login screen — blurred dark wallpaper from our branding/.
# (gnome-shell uses this on the lock screen / login greeter.)
[org/gnome/desktop/screensaver]
picture-uri='file:///usr/share/backgrounds/trailcurrent-playbill/wallpaper-dark.png'
picture-options='zoom'
