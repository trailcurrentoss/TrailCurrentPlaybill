#!/bin/bash
# TrailCurrent Playbill — MOTD banner
# Installed at /etc/update-motd.d/10-trailcurrent

GREEN=$'\033[32m'
BGREEN=$'\033[92m'
TEAL=$'\033[38;5;30m'
BOLD=$'\033[1m'
GRAY=$'\033[38;5;245m'
RESET=$'\033[0m'

REL=""
if [ -f /etc/playbill-release ]; then
    . /etc/playbill-release
    REL=" v${PLAYBILL_VERSION:-?}"
fi

UPTIME=$(uptime -p 2>/dev/null | sed 's/^up //')

echo ""
echo "${GREEN}                  /\\${RESET}"
echo "${GREEN}                 /  \\${RESET}"
echo "${GREEN}                /    \\${RESET}"
echo "${GREEN}               /      \\${RESET}"
echo "${GREEN}        /\\    /        \\${RESET}"
echo "${GREEN}       /  \\  /          \\${RESET}"
echo "${GREEN}      /    \\/            \\${RESET}"
echo "${GREEN}     /                    \\${RESET}"
echo "${GREEN}    /  ${BGREEN}~~~${GREEN}            ${BGREEN}~~~${GREEN}  \\${RESET}"
echo "${GREEN}   / ${BGREEN}~~   ~~${GREEN}      ${BGREEN}~~~   ~~${GREEN} \\${RESET}"
echo "${GREEN}  /____________________________\\${RESET}"
echo ""
echo "  ${BOLD}${GREEN}Trail${TEAL}Current${RESET} ${BOLD}Playbill${RESET}${REL}"
echo "  ${GRAY}TrailCurrent Desktop  |  Radxa Dragon Q6A${RESET}"
[ -n "$UPTIME" ] && echo "  ${GRAY}up ${UPTIME}${RESET}"
echo ""
