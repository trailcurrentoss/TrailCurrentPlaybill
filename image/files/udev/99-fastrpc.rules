# TrailCurrent Playbill — FastRPC / Hexagon NPU device permissions.
#
# /dev/fastrpc-cdsp        — Compute DSP (Hexagon NPU) RPC channel
# /dev/fastrpc-cdsp-secure — secured CDSP channel (used by some QNN configs)
# /dev/fastrpc-adsp        — Audio DSP RPC channel (kept open for parity)
# dma_heap/system          — DMA heap allocator the FastRPC stack uses for
#                            shared buffers between APPS and DSP.
#
# Default kernel perms are 0600 root:root which prevents the trailcurrent
# user from opening the NPU. We pair this with `render` group membership
# (added in rootfs.jsonnet hook 3) — even with mode 0666 the dma_heap path
# wants the calling process in render/video on some kernels.
#
# Source: https://gist.github.com/Foadsf/2972e8059102ad9bc9c5848ae1fc7cc3
KERNEL=="fastrpc-cdsp",        MODE="0666"
KERNEL=="fastrpc-cdsp-secure", MODE="0666"
KERNEL=="fastrpc-adsp",        MODE="0666"
SUBSYSTEM=="dma_heap", KERNEL=="system", MODE="0666"
