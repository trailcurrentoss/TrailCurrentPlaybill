// SPDX-License-Identifier: BSD-3-Clause
//
// Playbill Q6A — disable all 40-pin header GPIOs we don't use.
//
// Defense-in-depth against EMI / floating-pin issues like the one that
// caused the early-boot menu trap on UART RX (gpio23 / header pin 10).
// The Playbill image binds the Waveshare RS485 CAN HAT-B and the QCM6490
// debug UART; everything else on the 40-pin header is unused. Without an
// explicit owner, those unused pins sit in their reset state — typically
// GPIO+input with no bias — which leaves them exposed to capacitive
// coupling from adjacent active lines (the SPI clocks on gpio48-51 switch
// at MHz rates and sit right next to half the unused header pins).
//
// This overlay claims each unused header pin via a `gpio-hog` node:
//   * locks the kernel pinmux so no future driver can rebind these pins
//     to a peripheral function (UART, I2C, SPI, PWM, etc.)
//   * configures each as a GPIO input
//   * gives each a stable kernel-visible line-name for diagnostics
//
// Pins NOT included (deliberately left alone):
//   gpio22 (PIN_8 UART_TX) and gpio23 (PIN_10 UART_RX) — these are the
//   debug UART (ttyMSM0). The kernel keeps them muxed as UART for console
//   I/O. The phantom-input issue on gpio23 is mitigated upstream of the
//   kernel by patching UEFI BootAskValid + ConIn (see
//   files/scripts/playbill-firstboot.sh §1b), so we do not need to
//   wrest these pins from the UART driver.
//
//   HAT-used GPIOs (gpio29, 48, 49, 50, 51, 57, 97, 98, 99, 100) — owned
//   by the MCP2515 / SPI12 / SC16IS752 bindings in the OS DT and the CAN
//   overlay; touching them here would conflict.
//
//   gpio1 (PIN_15) — owned by the playbill-ir-recv overlay (gpio-ir-receiver
//   on the 40-pin header, PIN_15 signal + PIN_1 3V3 + PIN_9 GND).
//
//   gpio24 (PIN_3) — left HOGGED here even though it is unused for I/O, to
//   prevent any future driver from rebinding I2C7_SDA. Do NOT move the IR
//   signal back to gpio24: the pre-kernel firmware probes I2C7 for HAT-EEPROM
//   and hangs the boot if SDA is held by a non-I2C device. (Confirmed
//   empirically 2026-05-13: PIN_3 hung boot.)
//
//   gpio25 (PIN_5) — also left HOGGED here, even though we briefly used it
//   for the IR signal. Empirically the IR was unreliable on PIN_5 (decoder
//   drops frames after a few presses) because the pad's primary alt-function
//   is I2C7_SCL and the muxed-out state interacts badly with bias settings.
//   IR moved to PIN_15 (gpio1) 2026-05-14.
//
// Header→GPIO mapping (from /sys/firmware/devicetree/base/.../gpio-line-names
// at runtime — gpio-line-names property of the tlmm pinctrl node):
//   gpio0  → PIN_13       gpio26 → PIN_16       gpio55 → PIN_26
//   gpio24 → PIN_3        gpio27 → PIN_18       gpio56 → PIN_33
//   gpio8  → PIN_27       gpio28 → PIN_31       gpio58 → PIN_37
//   gpio9  → PIN_28       gpio30 → PIN_32       gpio59 → PIN_36
//   gpio25 → PIN_5        gpio31 → PIN_29       gpio96 → PIN_7
//
// All 15 of those are claimed by gpio-hog entries below.

/dts-v1/;
/plugin/;

/ {
	metadata {
		title = "Disable unused 40-pin header GPIOs (Playbill Q6A)";
		compatible = "radxa,dragon-q6a";
		category = "misc";
		exclusive = "gpio0", "gpio8", "gpio9",
			    "gpio24", "gpio25", "gpio26",
			    "gpio27", "gpio28", "gpio30",
			    "gpio31", "gpio55", "gpio56",
			    "gpio58", "gpio59", "gpio96";
		description = "Lock unused 40-pin header GPIOs as kernel-claimed input pins so no
peripheral driver can rebind them and so they're explicitly owned in
the kernel's pinmux state. Playbill defense-in-depth against
floating-pin EMI issues.";
	};
};

&tlmm {
	playbill-unused-pin13 {
		gpio-hog;
		gpios = <0 0>;
		input;
		line-name = "playbill-unused-PIN_13";
	};

	playbill-unused-pin5 {
		gpio-hog;
		gpios = <25 0>;
		input;
		line-name = "playbill-unused-PIN_5";
	};

	playbill-unused-pin27 {
		gpio-hog;
		gpios = <8 0>;
		input;
		line-name = "playbill-unused-PIN_27";
	};

	playbill-unused-pin28 {
		gpio-hog;
		gpios = <9 0>;
		input;
		line-name = "playbill-unused-PIN_28";
	};

	playbill-unused-pin3 {
		gpio-hog;
		gpios = <24 0>;
		input;
		line-name = "playbill-unused-PIN_3";
	};

	playbill-unused-pin16 {
		gpio-hog;
		gpios = <26 0>;
		input;
		line-name = "playbill-unused-PIN_16";
	};

	playbill-unused-pin18 {
		gpio-hog;
		gpios = <27 0>;
		input;
		line-name = "playbill-unused-PIN_18";
	};

	playbill-unused-pin31 {
		gpio-hog;
		gpios = <28 0>;
		input;
		line-name = "playbill-unused-PIN_31";
	};

	playbill-unused-pin32 {
		gpio-hog;
		gpios = <30 0>;
		input;
		line-name = "playbill-unused-PIN_32";
	};

	playbill-unused-pin29 {
		gpio-hog;
		gpios = <31 0>;
		input;
		line-name = "playbill-unused-PIN_29";
	};

	playbill-unused-pin26 {
		gpio-hog;
		gpios = <55 0>;
		input;
		line-name = "playbill-unused-PIN_26";
	};

	playbill-unused-pin33 {
		gpio-hog;
		gpios = <56 0>;
		input;
		line-name = "playbill-unused-PIN_33";
	};

	playbill-unused-pin37 {
		gpio-hog;
		gpios = <58 0>;
		input;
		line-name = "playbill-unused-PIN_37";
	};

	playbill-unused-pin36 {
		gpio-hog;
		gpios = <59 0>;
		input;
		line-name = "playbill-unused-PIN_36";
	};

	playbill-unused-pin7 {
		gpio-hog;
		gpios = <96 0>;
		input;
		line-name = "playbill-unused-PIN_7";
	};
};
